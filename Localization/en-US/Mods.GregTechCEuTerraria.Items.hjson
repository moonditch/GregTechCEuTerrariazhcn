	Tooltip:
		'''
		An inert casing etched reactive in an HV chemical reactor
		Use on the surface to summon the Caustic Reactor
		'''
}

OverburnedCoilBlock: {
	DisplayName: Overburned Coil Block
	Tooltip:
		'''
		A cupronickel coil block stoked past its limit
		Use on the surface to summon the Fallen EBF
		'''
}

unstable_compressor_charge: {
	DisplayName: Unstable Compressor Charge
	Tooltip:
		'''
		A steel casing packed with ITNT, primed in a Large Chemical Reactor
		Use on the surface to summon the Implosion Press
		'''
}

dirty_stainless_steel_casing: {
	DisplayName: Dirty Stainless Steel Casing
	Tooltip:
		'''
		A stainless casing clogged with soul residue
		Use in hardmode to summon the Soul Distiller
		'''
}

frozen_frostproof_casing: {
	DisplayName: Frozen Frostproof Casing
	Tooltip:
		'''
		A frost-proof casing frozen solid in an HV chemical bath
		Use on the surface to summon the Vacuum Freezer
		'''
}

GregTechIronToolsBag: {
	DisplayName: Starter Bag: Iron Tools
	Tooltip:
		'''
		Right-click to open. Drops the iron-tier crafting catalysts:
		hammer, wrench, wire cutter, file, screwdriver, saw, mortar, crowbar, knife.
		'''
}

simple_fluid_pipe: {
	DisplayName: Simple Fluid Pipe
	Tooltip: ""
}

simple_item_pipe: {
	DisplayName: Simple Item Pipe
	Tooltip: ""
}

SkipStoneAgeBag: {
	DisplayName: Starter Bag: Skip Stone Age
	Tooltip:
		'''
		Right-click to open. Drops a steam-age auto-mining setup so you can skip manual mining:
		HP steam miner, two HP coal boilers, bronze crates, HP steam furnace + macerator,
		coke fuel, fluid + item pipes, and the primitive-pump + coke-oven multiblock bags.
		'''
}

SteamAgeSkipBag: {
	DisplayName: Starter Bag: Skip Steam Age
	Tooltip:
		'''
		Right-click to open. Drops an LV-tier bootstrap kit so you can skip the Bronze / Steam age:
		4x LV solar panel + 4x LV lamp + LV 4x battery buffer + 1 sodium battery,
		4 LV machine hulls + circuits + plates + rods + wires for assembling LV machines,
		and a stack of simple item + fluid pipes.
		'''
}

TooManyItemsItem: {
	DisplayName: Too Many Items
	Tooltip:
		'''
		Place anywhere * right-click to open the global recipe browser.

		[c/FFE68C:Search syntax]
		  iron rod        - recipes containing 'iron' AND 'rod' (substring match)
		  platform        - finds Terraria item-name matches (e.g. plank-substituted)
		  @bender         - only bender recipes
		  @assemb         - assembler AND assembly_line (substring on station)
		  @bend ir pla    - bender recipes that also reference iron plate

		[c/FFE68C:Controls]
		  LMB on bar      - focus, start typing
		  RMB on bar      - clear search
		  LMB outside bar - unfocus
		  Esc / X         - close browser
		  Hover ingredient cell - tooltip with chance / tool info
		'''
}

