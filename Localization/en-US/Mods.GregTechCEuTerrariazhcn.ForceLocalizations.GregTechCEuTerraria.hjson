				BuildFilterEditor: {
					1: {
						OldString: tag expression  *  e.g.  *dusts/gold | !*lv
						NewString: tag expression  *  e.g.  *dusts/gold | !*lv
					}

					2: {
						OldString:
							'''
							Accepts complex expressions:
							a & b = AND   *   a | b = OR   *   a ^ b = XOR
							!a = NOT   *   (a) for grouping
							* = wildcard   *   $ = untagged
							Tags are 'namespace:tag/subtype'.
							The 'forge:' namespace is assumed if one isn't given.
							Example: *dusts/gold | (gtceu:circuits & !*lv)
							Type, then press Enter (or click away) to set.
							'''
						NewString:
							'''
							Accepts complex expressions:
							a & b = AND   *   a | b = OR   *   a ^ b = XOR
							!a = NOT   *   (a) for grouping
							* = wildcard   *   $ = untagged
							Tags are 'namespace:tag/subtype'.
							The 'forge:' namespace is assumed if one isn't given.
							Example: *dusts/gold | (gtceu:circuits & !*lv)
							Type, then press Enter (or click away) to set.
							'''
					}

					3: {
						OldString:
							'''
							Whitelist - only listed items are pulled
							Blacklist - listed items are NOT pulled
							(an empty whitelist pulls nothing)
							'''
						NewString:
							'''
							Whitelist - only listed items are pulled
							Blacklist - listed items are NOT pulled
							(an empty whitelist pulls nothing)
							'''
					}

