						OldString: e.g. *dusts/iron
						NewString: e.g. *dusts/iron
					}

					10: {
						OldString:
							'''
							Accepts complex expressions:
							a & b = AND   *   a | b = OR   *   a ^ b = XOR
							!a = NOT   *   (a) for grouping
							* = wildcard   *   $ = untagged
							Tags are 'namespace:tag/subtype' (forge: assumed by default).
							Type, then press Enter (or click away) to set.
							'''
						NewString:
							'''
							Accepts complex expressions:
							a & b = AND   *   a | b = OR   *   a ^ b = XOR
							!a = NOT   *   (a) for grouping
							* = wildcard   *   $ = untagged
							Tags are 'namespace:tag/subtype' (forge: assumed by default).
							Type, then press Enter (or click away) to set.
							'''
					}

					11: {
						OldString:
							'''
							Which direction the filter applies to
