			TooManyItemsItem: {
				Tooltip:
					'''
					任意位置放置后右击打开全局配方浏览器。

					[c/FFE68C:搜索语法]
					  iron rod        - 包含 'iron' 和 'rod' 的配方（子串匹配）
					  platform        - 匹配泰拉瑞亚物品名（如木板替代品）
					  @bender         - 仅显示卷板机配方
					  @assemb         - 组装机和装配线配方（站名子串匹配）
					  @bend ir pla    - 含铁板的卷板机配方

					[c/FFE68C:操作方式]
					  鼠标左键搜索栏      - 聚焦，开始输入
					  鼠标右键搜索栏      - 清空搜索
					  鼠标左键栏外        - 取消聚焦
					  Esc / X             - 关闭浏览器
					  悬停材料格子        - 显示几率/工具信息
					'''
				DisplayName: 太多物品
			}

			frozen_frostproof_casing: {
				Tooltip:
					'''
					在HV化学浸洗机中冻结固化的防冻机械方块
					在地表使用可召唤真空冷冻机
					'''
				DisplayName: 防冻机械方块
			}

			dirty_stainless_steel_casing: {
				Tooltip:
					'''
					被灵魂残渣堵塞的不锈钢外壳
					在困难模式下使用可召唤灵魂蒸馏机
					'''
				DisplayName: 污损不锈钢外壳
			}

			OverburnedCoilBlock: {
				Tooltip:
					'''
					一块被过度加热到极限的白铜线圈方块
					在地表使用可召唤坠落电力高炉
					'''
				DisplayName: 过热线圈方块
			}

			acid_etched_inert_casing: {
				Tooltip:
					'''
					在HV化学反应釜中被蚀刻得具备反应活性的惰性机械方块
					在地表使用可召唤腐蚀反应堆
					'''
				DisplayName: 酸蚀惰性机械方块
			}

			unstable_compressor_charge: {
				DisplayName: 不稳定压缩机装药
				Tooltip:
					'''
					填满工业TNT的钢制外壳，在大型化学反应釜中完成引爆准备
					在地表使用可召唤聚爆压缩机
					'''
			}

			GregTechIronToolsBag: {
				DisplayName: 新手包：铁质工具
				Tooltip:
					'''
					右击打开，投出铁质工具套装：
					锤、扳手、剪线钳、锉刀、螺丝刀、锯、研钵、撬棍、刀。
					'''
			}

			SkipStoneAgeBag: {
				DisplayName: 新手包：跳过石器时代
				Tooltip:
					'''
					右击打开，投出蒸汽时代自动化采矿套装，助你跳过手动采矿：
					高压蒸汽采矿机、两台高压燃煤锅炉、青铜板条箱、高压蒸汽熔炉+研磨机、
					焦炭燃料、流体+物品管道，以及原始水泵+焦炉多方块结构袋。
					'''
			}

			SteamAgeSkipBag: {
				DisplayName: 新手包：跳过蒸汽时代
				Tooltip:
					'''
					右击打开，投出LV级别启动套件，助你跳过青铜/蒸汽时代：
					4x LV太阳能板 + 4x LV灯 + LV 4x电池箱 + 1个钠电池、
					4个LV机器外壳 + 电路 + 板 + 杆 + 导线用于组装LV机器、
					以及一组简易物品+流体管道。
					'''
			}

